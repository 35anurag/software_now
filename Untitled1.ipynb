"""
Assignment: File Encryption and Decryption System
Authors: Bibek Khakural, Bivek Pantha

Description:
This program:
1. Reads text from 'raw_text.txt'
2. Encrypts it using custom rules
3. Saves to 'encrypted_text.txt'
4. Decrypts it back to 'decrypted_text.txt'
5. Verifies correctness
"""

# -------------------------------
# File Handling Utilities
# -------------------------------

def create_raw_file():
    """Creates a sample raw text file."""
    content = """Hello World!
This is my encryption test.
abc xyz ABC XYZ"""
    
    with open("raw_text.txt", "w") as f:
        f.write(content)
    print("✅ raw_text.txt created")


def read_file(filename):
    with open(filename, "r") as f:
        return f.read()


def write_file(filename, content):
    with open(filename, "w") as f:
        f.write(content)


# -------------------------------
# Encryption Logic
# -------------------------------

def encrypt_char(ch, shift1, shift2):
    """Encrypt a single character based on rules."""
    
    if ch.islower():
        pos = ord(ch) - ord('a')
        
        if pos <= 12:  # a-m
            new_pos = (pos + shift1 * shift2) % 26
            return chr(new_pos + ord('a')) + "1"
        else:  # n-z
            new_pos = (pos - (shift1 + shift2)) % 26
            return chr(new_pos + ord('a')) + "2"

    elif ch.isupper():
        pos = ord(ch) - ord('A')
        
        if pos <= 12:
            new_pos = (pos - shift1) % 26
            return chr(new_pos + ord('A')) + "3"
        else:
            new_pos = (pos + shift2**2) % 26
            return chr(new_pos + ord('A')) + "4"

    return ch


def encrypt_file(shift1, shift2):
    text = read_file("raw_text.txt")
    result = "".join(encrypt_char(ch, shift1, shift2) for ch in text)
    
    write_file("encrypted_text.txt", result)
    print("✅ Encryption completed")


# -------------------------------
# Decryption Logic
# -------------------------------

def decrypt_char(ch, rule, shift1, shift2):
    """Decrypt a single character using its rule marker."""
    
    if ch.islower():
        pos = ord(ch) - ord('a')
        
        if rule == "1":
            new_pos = (pos - shift1 * shift2) % 26
        else:
            new_pos = (pos + (shift1 + shift2)) % 26
        
        return chr(new_pos + ord('a'))

    elif ch.isupper():
        pos = ord(ch) - ord('A')
        
        if rule == "3":
            new_pos = (pos + shift1) % 26
        else:
            new_pos = (pos - shift2**2) % 26
        
        return chr(new_pos + ord('A'))

    return ch


def decrypt_file(shift1, shift2):
    text = read_file("encrypted_text.txt")
    result = ""
    
    i = 0
    while i < len(text):
        ch = text[i]

        if ch.isalpha() and i + 1 < len(text):
            rule = text[i + 1]
            result += decrypt_char(ch, rule, shift1, shift2)
            i += 2
        else:
            result += ch
            i += 1

    write_file("decrypted_text.txt", result)
    print("✅ Decryption completed")


# -------------------------------
# Verification
# -------------------------------

def verify_files():
    original = read_file("raw_text.txt")
    decrypted = read_file("decrypted_text.txt")
    
    if original == decrypted:
        print("✅ SUCCESS: Decryption matches original!")
    else:
        print("❌ FAILURE: Decryption does NOT match")


# -------------------------------
# Display Output
# -------------------------------

def show_files():
    print("\n--- RAW TEXT ---")
    print(read_file("raw_text.txt"))

    print("\n--- ENCRYPTED TEXT ---")
    print(read_file("encrypted_text.txt"))

    print("\n--- DECRYPTED TEXT ---")
    print(read_file("decrypted_text.txt"))


# -------------------------------
# Input Handling
# -------------------------------

def get_shift_input():
    """Ensures valid integer input."""
    while True:
        try:
            shift1 = int(input("Enter shift1: "))
            shift2 = int(input("Enter shift2: "))
            return shift1, shift2
        except ValueError:
            print("❌ Please enter valid integers!")


# -------------------------------
# Main Program
# -------------------------------

def main():
    print("=== Encryption/Decryption System ===")

    create_raw_file()
    shift1, shift2 = get_shift_input()

    encrypt_file(shift1, shift2)
    decrypt_file(shift1, shift2)
    verify_files()
    show_files()


if __name__ == "__main__":
    main()
